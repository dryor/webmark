{
  "name": "@webmarkjs/cli",
  "version": "0.0.4",
  "description": "Terminal interface for webmark — synthetic web performance measurement with statistical aggregation.",
  "keywords": [
    "web performance",
    "lighthouse",
    "core web vitals",
    "cli",
    "LCP",
    "FCP",
    "CLS",
    "TTI",
    "metrics",
    "benchmark"
  ],
  "homepage": "https://github.com/dryor/webmarkjs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dryor/webmarkjs.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/dryor/webmarkjs/issues"
  },
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "webmark": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib",
    "check": "biome check --write",
    "dev": "rslib --watch",
    "format": "biome format --write",
    "lint": "biome check",
    "test": "rstest",
    "test:watch": "rstest --watch"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@webmarkjs/core": "workspace:*",
    "cac": "^6.7.14",
    "chrome-launcher": "^1.2.1",
    "lighthouse": "^13.3.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@rslib/core": "^0.22.0",
    "@rstest/adapter-rslib": "^0.10.2",
    "@rstest/core": "^0.10.2",
    "@types/node": "^24.12.4",
    "typescript": "^6.0.3"
  }
}
